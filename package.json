{
  "name": "backend",
  "version": "1.1.0",
  "description": "নব্য দিগন্ত এন জিও। - Professional NGO Management API",
  "main": "index.js",
  "scripts": {
    "dev": "node index.js",
    "start": "node index.js",
    "start:watch": "nodemon index.js",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js",
    "stop": "powershell -NoProfile -Command \"Get-NetTCPConnection -LocalPort 5000 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }\"",
    "seed:demo": "node scripts/importDemoData.js",
    "seed:demo:keep": "node scripts/importDemoData.js --keep",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\""
  },
  "keywords": [
    "ngo",
    "savings",
    "loan",
    "management",
    "microfinance",
    "bangladesh"
  ],
  "author": "নব্য দিগন্ত এন জিও।",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
